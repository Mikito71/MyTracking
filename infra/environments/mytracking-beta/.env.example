# MyTracking beta environment
# Copy this file to .env on the OVH server and fill values outside git.

COMPOSE_PROJECT_NAME=mytracking-beta

# Public URLs
MYTRACKING_BETA_HOST=mytracking-beta.51-210-14-228.sslip.io
WEB_PUBLIC_URL=https://mytracking-beta.51-210-14-228.sslip.io
API_PUBLIC_URL=https://mytracking-beta.51-210-14-228.sslip.io/api

# PostgreSQL control plane
POSTGRES_DB=mytracking_control_beta
POSTGRES_USER=mytracking_beta
POSTGRES_PASSWORD=change-me-outside-git

# Application secrets
JWT_SECRET=change-me-outside-git
SESSION_SECRET=change-me-outside-git

# Admin beta access
ADMIN_EMAIL=mikael.jurgielewicz@cw2s.fr
ADMIN_PASSWORD_SHA256=change-me-outside-git
ADMIN_SESSION_SECRET=change-me-outside-git
CLIENT_PASSWORD_SHA256=change-me-outside-git

# Images will be replaced when the app skeleton exists.
WEB_IMAGE=nginx:alpine
API_IMAGE=nginx:alpine

# Reverse proxy
HTTP_BIND=127.0.0.1
HTTP_PORT=3100

# Optional destructive beta reset/import command.
# This must be filled only on the server, never with secrets committed here.
# The command is executed inside the admin-auth container when an admin clicks
# "Synchroniser WinDev".
WINDEV_SYNC_COMMAND=node /app/sync-windev-sga.js
WINDEV_SYNC_TIMEOUT_MS=900000
